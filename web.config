<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyInboundRule1" stopProcessing="true">
          <match url="^Services/(.*)" />
          <action type="Rewrite" url="http://localhost:5000/Services/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>